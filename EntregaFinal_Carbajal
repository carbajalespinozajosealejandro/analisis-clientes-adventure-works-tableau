          <zone forceUpdate='true' h='97962' id='3' type-v2='text' w='49513' x='50000' y='1019'>
            <formatted-text>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>OBJETIVO DEL ANÁLISIS</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>Identificar el perfil de los clientes de Adventure Works, </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>analizar patrones de compra de bicicletas y segmentar </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>clientes por ingreso, ocupación y grupo etario para </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>optimizar estrategias de marketing y ventas.</run>
              <run fontalignment='1'>Æ&#10;&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>FUENTE DE DATOS</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>Origen: Kaggle — Adventure Works Dataset</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>Tablas: AWCustomers.csv (18.361 clientes) y AWSales.csv</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>Contenido: Datos demográficos de clientes, si compraron </run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>bicicleta (BikeBuyer) y gasto mensual promedio (AvgMonthSpend).</run>
              <run fontalignment='1'>Æ&#10;&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>USUARIOS DESTINATARIOS</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>- Gerente Comercial: para definir segmentos objetivo</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>- Equipo de Marketing: para campañas segmentadas</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='12'>- Analista de Datos: para exploración y modelado</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone forceUpdate='true' h='97962' id='5' type-v2='text' w='49513' x='487' y='1019'>
            <formatted-text>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>MODELO RELACIONAL</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>JOIN entre AWCustomers y AWSales mediante el campo</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>CustomerID (clave primaria). Tipo: Inner Join.</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>Resultado: 18.355 registros con datos completos.</run>
              <run fontalignment='1'>Æ&#10;&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>CAMPOS CALCULADOS CREADOS</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>- Ingreso Anual (Miles): YearlyIncome / 1000</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>- Segmento de Ingresos: clasifica en Alto/Medio/Bajo/Muy Bajo</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>- Estado Comprador: etiqueta BikeBuyer como Compró/No Compró</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>- Gasto Anual Estimado: AvgMonthSpend × 12</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>- Promedio Gasto por País (LOD): FIXED por país</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>- Diferencia vs Promedio País: gasto individual vs promedio país</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>- Edad del Cliente: DATEDIFF desde BirthDate a hoy</run>
              <run fontalignment='1'>Æ&#10;</run>
              <run fontalignment='1' fontcolor='#000000' fontsize='10'>- Grupo Etario: clasifica por rangos de edad</run>
              <run fontalignment='1'>Æ&#10;</run>
